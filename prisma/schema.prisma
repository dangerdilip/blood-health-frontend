generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id // Clerk userId
  createdAt DateTime @default(now())
  records   Record[]
}

model Record {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  date       String   // Format YYYY-MM-DD
  hemoglobin Float
  wbc        Float
  platelets  Float
  rbc        Float
  mcv        Float
  mch        Float
  mchc       Float
  createdAt  DateTime @default(now())
}
